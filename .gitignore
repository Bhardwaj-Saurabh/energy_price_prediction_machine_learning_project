# Python build artefacts
__pycache__/
*.py[cod]
*$py.class
build/
dist/
wheels/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# uv
# We DO commit uv.lock for reproducible installs — do not ignore it.

# Test, type-check, coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# Secrets — never commit real secrets. .env.example is the template that IS committed.
.env
.env.*
!.env.example

# Data — large, regenerable, versioned via DVC later.
data/
*.parquet
*.csv
*.feather
*.h5

# Notebooks — exploration only, not deliverables.
notebooks/
*.ipynb_checkpoints

# MLflow / Feast / Kedro local stores (added now so they're never committed by accident)
mlruns/
mlartifacts/
feast_repo/data/online_store.db
feast_repo/data/registry.db
.kedro/

# IDE / OS noise
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Working files from the PRD conversion (kept locally, never committed)
_docx_v3/
