# Energy Forecaster — environment variables template.
#
# Copy this file to .env (gitignored) and fill in real values. Variables
# without the EF_ prefix are ignored by the Settings loader — the prefix
# both prevents collisions with other tools and lets `extra=forbid` catch
# typos in our own variables.
#
# All values here are OPTIONAL until the relevant feature is wired up.
# Defaults from src/energy_forecaster/config/settings.py apply otherwise.

# Deployment environment. Drives composition-root branching only —
# never reference this from business code. Allowed: local, prod.
EF_ENVIRONMENT=local

# Logging verbosity. Allowed: DEBUG, INFO, WARNING, ERROR, CRITICAL.
EF_LOG_LEVEL=INFO

# Where local-mode adapters write data on disk. Relative paths are
# resolved against the working directory.
EF_LOCAL_DATA_ROOT=./data

# ENTSO-E Transparency Platform API key. Request one at
# https://transparency.entsoe.eu (Account Settings → Web API Security Token).
# Leave empty until the ingestion adapter is added; setting it now has no
# effect on behaviour.
EF_ENTSOE_API_KEY=
